{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "1",
    "CLAUDE_CODE_PACKAGE_MANAGER_AUTO_UPDATE": "1",
    "NODE_OPTIONS": "--max-old-space-size=8192"
  },
  "permissions": {
    "allow": [
      {{- if eq .chezmoi.os "darwin" }}
      "Bash(GOOGLE_CLOUD_PROJECT=\"optable-platform-dev\" GOOGLE_CLOUD_REGION=\"northamerica-northeast1\" go test:*)",
      {{- end }}
      "Bash(emacsclient:*)",
      "Bash(gh label list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr view:*)",
      "Bash(gh run view:*)",
      "Bash(gh search code:*)",
      "Bash(git blame:*)",
      "Bash(git log:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(go build:*)",
      "Bash(go doc:*)",
      "Bash(go mod tidy)",
      "Bash(go test:*)",
      "Bash(go tool pprof:*)",
      "Bash(go vet:*)",
      "Bash(gofmt:*)",
      "Bash(golangci-lint:*)",
      "Bash(git branch:*)",
      "Bash(git diff:*)",
      "Bash(git stash list:*)",
      "Bash(head:*)",
      "Bash(kubectl get pods:*)",
      "Bash(kubectl logs:*)",
      "Bash(ls:*)",
      "Bash(lsof:*)",
      "Bash(pwd:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      {{- if eq .chezmoi.os "darwin" }}
      "mcp__claude_ai_Slack__slack_search_public",
      "mcp__claude_ai_Slack__slack_search_public_and_private",
      "mcp__claude_ai_Slack__slack_search_channels",
      "mcp__claude_ai_Slack__slack_search_users",
      {{- end }}
      "WebFetch(domain:docs.cloud.google.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:docs.sentry.io)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:google.aip.dev)",
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/find-guard.sh"
          }
        ]
      }
    ]
  },
  "fileSuggestion": {
    "type": "command",
    "command": "~/.claude/file-suggestion.sh"
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "enabledPlugins": {
    {{- if eq .chezmoi.os "darwin" }}
    "typescript-lsp@claude-plugins-official": true,
    {{- else if (eq .chezmoi.os "linux") }}
    "gopls-lsp@claude-plugins-official": true,
    {{- end }}
    "chrome-devtools-mcp@chrome-devtools-plugins": true
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "api.clickup.com",
        "api.github.com",
        "github.com",
        "sentry.io"
      ]
    }
  },
  "alwaysThinkingEnabled": true,
  "tui": "fullscreen",
  "theme": "auto"
}
